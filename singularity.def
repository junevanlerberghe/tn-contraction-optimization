Bootstrap: docker
From: python:3.13-slim

%help
    This is a Singularity container for the TN Contraction Optimization project.

%labels
    Author June Vanlerberghe
    Version 1.0
    Description Singularity container for tensor network contraction optimization.

%files
    ${CI_PROJECT_DIR} /opt/tn-contraction-optimization

%post
    export DEBIAN_FRONTEND=noninteractive

    # Update and install necessary packages
    apt-get update && apt-get install -y \
        build-essential \
        git \
        wget \
        cmake \
        libopenblas-dev \
        liblapack-dev \
        && apt-get clean

    # Install Python dependencies
    pip install kahypar

    # Set up the working directory
    cd /opt/tn-contraction-optimization/
    git submodule update --init --recursive

    ls /opt/tn-contraction-optimization/planqtn
    cd /opt/tn-contraction-optimization/planqtn
    pip install .
    cd /opt/tn-contraction-optimization/cotengra
    pip install .

%environment
    # Set environment variables
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/opt/tn-contraction-optimization:$PATH

%runscript
    # Define the default command to run
    exec python3 /opt/tn-contraction-optimization/compass-code-complexity/compass-code-complexity.py "$@"

%test
    # Test if the container is set up correctly
    python3 --version
    echo "Container setup is complete."